# ===== Bloqueia acesso direto ao arquivo .env =====
<Files ".env">
    Require all denied
</Files>

# Fallback para compatibilidade com Apache 2.2 / configurações antigas
<IfModule !mod_authz_core.c>
    <Files ".env">
        Order allow,deny
        Deny from all
    </Files>
</IfModule>

# Bloqueia também qualquer variação (.env.example pode ficar público, mas por segurança bloqueamos todos os .env*)
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

RewriteEngine On

# Bloqueia acesso direto a pastas sensíveis
RewriteRule ^(app|config|database|routes)/ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

RewriteEngine On

# Bloqueia acesso direto a pastas sensíveis
RewriteRule ^(app|config|database|routes)/ - [F,L]

# Redireciona tudo para index.php, exceto arquivos/pastas reais
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ===== Compressão GZIP =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ===== Cache de arquivos estáticos =====
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# ===== Headers de segurança =====
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Desabilita listagem de diretórios
Options -Indexes